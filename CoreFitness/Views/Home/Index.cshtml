@{
    ViewData["Title"] = "Home";
}

<!-- ========== HERO ========== -->
<section class="hero-section">
    <div class="hero-inner">
        <div class="hero-text">
            <span class="hero-label">Strong Body. Strong Mind.</span>
            <h1>Build Strength Boost Confidence Today!</h1>
            <p>
                Begin your fitness journey with expert trainers, modern equipment, and a
                supportive environment designed to help you build strength and confidence.
            </p>
            <ul class="hero-bullets">
                <li>Transform your body with training</li>
                <li>Personal training for real results</li>
                <li>Build confidence through fitness</li>
                <li>Fitness tailored to your goals</li>
            </ul>
            <a href="#" class="btn-get-started">Get Started →</a>
        </div>
        <div class="hero-image">
            <span>[ Athletes Image ]</span>
        </div>
    </div>
</section>

<!-- ========== PARTNERS BAR ========== -->
<div class="partners-bar">
    <div class="partners-logos">
        <div class="partner-logo"><span class="partner-logo-icon"></span> Logoipsum</div>
        <div class="partner-logo"><span class="partner-logo-icon"></span> Logoipsum</div>
        <div class="partner-logo"><span class="partner-logo-icon"></span> Logoipsum</div>
        <div class="partner-logo"><span class="partner-logo-icon"></span> Logoipsum</div>
        <div class="partner-logo"><span class="partner-logo-icon"></span> Logoipsum</div>
    </div>
    <span class="partners-tagline">Modern Equipment</span>
</div>

<!-- ========== ABOUT ========== -->
<section class="about-section">
    <div class="about-images">
        <div class="about-img"></div>
        <div class="about-img"></div>
        <div class="about-img"></div>
        <div class="about-checkerboard"></div>
    </div>
    <div class="about-text">
        <span class="section-pill">+ About Us</span>
        <h2>Elevating Fitness Journey with Expert Guidance</h2>
        <p>
            We support every stage of your fitness journey with certified trainers, personalized
            programs and proven methods designed to help you train safely and build strength.
        </p>
        <div class="mission-quote">
            Our mission is to transform lives by combining expert guidance, powerful training
            programs, and a motivating community that helps you grow stronger every day.
        </div>
    </div>
</section>

<!-- ========== PROGRAMS ========== -->
<section class="programs-section">
    <div class="section-header">
        <span class="section-pill">+ Our Programs</span>
        <h2>Professional training program for stronger health</h2>
    </div>
    <div class="programs-grid">
        <div class="program-card"></div>
        <div class="program-card"></div>
        <div class="program-card"></div>
    </div>
    <p class="section-cta">
        Let's make something great work together. <a href="#">Get Free Quote</a>
    </p>
</section>

<!-- ========== STORE ========== -->
<section class="store-section">
    <div class="section-header">
        <span class="section-pill">+ Our Store</span>
        <h2>High quality fitness products built for results</h2>
    </div>
    <div class="products-grid">
        <div class="product-card">Dumbbell</div>
        <div class="product-card">Gym Bag</div>
        <div class="product-card">Fitness Tracker</div>
        <div class="product-card">Treadmill</div>
    </div>
    <p class="section-cta">
        Let's make something great work together. <a href="#">Get Free Quote</a>
    </p>
</section>
