@{
    ViewData["Title"] = "Home Page";
}

<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Strong Body. Strong Mind.
        </div>
        <h1 class="hero-title">Build Strength Boost Confidence Today!</h1>
        <p class="hero-subtitle hero-down">
            Begin your fitness journey with expert trainers, modern equipment, and a
            supportive environment designed to help you build strength and confidence.
        </p>
        <div class="hero-textholder hero-down">
            <div class="marktext ">
                <img src="~/images/Heromark.png" alt="herocheckmark" />
                <p>Transform your body with training</p>
            </div>
            <div class="marktext ">
                <img src="~/images/Heromark.png" alt="herocheckmark" />
                <p>Personal training for real results</p>
            </div>
            <div class="marktext not-same">
                <img src="~/images/Heromark.png" alt="herocheckmark" />
                <p>Build confidence through fitness</p>
            </div>
            <div class="marktext">
                <img src="~/images/Heromark.png" alt="herocheckmark" />
                <p>Fitness tailored to your goals</p>
            </div>
        </div>
        <hr class="hero-divider hero-down" />
        <a href="X" class="hero-cta">
            Get Started
            <span class="hero-cta-arrow">&#8250;</span>
        </a>
    </div>
    <div class="hero-image">
        <img src="~/images/hero-image.png" alt="Fitness trainers" />
    </div>
</section>

<section class="logos">
    <img src="~/images/Logos.png" alt="Logos" />
</section>

