@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="notfound-page">
    <div class="notfound-content">
        <div class="notfound-numbers">
            <span class="notfound-4">4</span>
            <div class="notfound-icon">
                <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
                    <circle cx="50" cy="50" r="45" stroke="#D6EB31" stroke-width="3" fill="white" />
                    <rect x="30" y="25" width="40" height="50" rx="4" fill="#f5f5f5" stroke="#333" stroke-width="2" />
                    <rect x="35" y="32" width="30" height="4" rx="2" fill="#D6EB31" />
                    <rect x="35" y="40" width="20" height="3" rx="1" fill="#ccc" />
                    <rect x="35" y="47" width="25" height="3" rx="1" fill="#ccc" />
                    <circle cx="68" cy="70" r="12" fill="#D6EB31" stroke="#333" stroke-width="2" />
                    <text x="64" y="75" font-size="14" font-weight="bold" fill="#333">!</text>
                </svg>
            </div>
            <span class="notfound-4">4</span>
        </div>
        <h1 class="notfound-title">Oops! page not found</h1>
        <p class="notfound-subtitle">The page you are looking for does not exist.</p>
        <a asp-controller="Home" asp-action="Index" class="auth-btn notfound-btn">
            Back to Homepage <span class="btn-arrow">&#8250;</span>
        </a>
    </div>
</div>