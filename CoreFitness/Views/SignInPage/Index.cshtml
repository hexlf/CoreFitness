@model CoreFitness.Models.SignInViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to your CoreFitness account</p>
        </div>

        <form asp-controller="SignInPage" asp-action="SignIn" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-error"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-input" type="email" placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-input" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="auth-btn">Sign In</button>
        </form>

        <p class="auth-switch">
            Don't have an account? <a asp-controller="SignUp" asp-action="Index">Create one</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}