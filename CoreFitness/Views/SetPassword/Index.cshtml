@model CoreFitness.Models.SetPasswordViewModel
@{
    ViewData["Title"] = "Set Your Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title">Set Your Password</h1>
            <p class="auth-subtitle">
                Set a strong password to protect your account. For security reasons, your password must be at
                least 8 characters long and include uppercase and lowercase letters, numbers, and special
                characters.
            </p>
        </div>

        <div class="auth-divider"></div>

        <form asp-controller="SetPassword" asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-error"></div>

            <input asp-for="Email" type="hidden" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName" class="form-label">First Name <span class="required">*</span></label>
                    <input asp-for="FirstName" class="form-input" placeholder="Enter First Name" autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName" class="form-label">Last Name <span class="required">*</span></label>
                    <input asp-for="LastName" class="form-input" placeholder="Enter Last Name" autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input value="@Model.Email" class="form-input form-input--readonly" type="email" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password <span class="required">*</span></label>
                <input asp-for="Password" class="form-input" type="password" placeholder="Enter Password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="required">*</span></label>
                <input asp-for="ConfirmPassword" class="form-input" type="password" placeholder="Repeat Password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="auth-btn">
                Continue <span class="btn-arrow">&#8250;</span>
            </button>

            <div class="auth-terms">
                <label class="terms-toggle">
                    <input asp-for="AcceptTerms" type="checkbox" class="terms-checkbox" />
                    <span class="terms-slider"></span>
                </label>
                <span class="terms-label">Accept user terms and conditions</span>
                <span asp-validation-for="AcceptTerms" class="field-error"></span>
            </div>
        </form>

        <p class="auth-switch">
            Already have an account? <a asp-controller="SignInPage" asp-action="Index">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}